UVICORN_SERVER_HOST=0.0.0.0
UVICORN_SERVER_PORT=28000

# in-memory repo
MEM_MAX_BYTES=314572800

# tiles storage
TILES_BACKEND=s3
TILES_FS_DIR=./data
TILES_BUCKET=palleon-track

# tiles cache
TILES_CACHE_TTL=120
TILES_CACHE_MAX_ITEMS=50000
TILES_CACHE_MAX_BYTES=536870912

#
RABBIT_URL=amqp://guest:guest@localhost:5672/
RABBIT_QUEUE=tile.build
RABBIT_RETRY_QUEUE=tile.build.retry
RABBIT_DLQ=tile.build.dlq

TILE_BUILD_MAX_RETRIES=5
TILE_BUILD_RETRY_DELAY_MS=10000

MONGO_JOBS_COLLECTION=tile_jobs
MONGO_JOBS_TTL_SECONDS=604800